[layer_names]

3d_physics/layer_1="player"
3d_physics/layer_2="enemy"
3d_physics/layer_3="player_projectile"
3d_physics/layer_4="enemy_projectile"
3d_physics/layer_5="pickup"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
lights_and_shadows/directional_shadow/size=16384
lights_and_shadows/directional_shadow/size.mobile=8192

[signal_bus]

signals={
"player_HP_updated": [{
"name": "new_hp",
"type": 3
}, {
"name": "previous_hp",
"type": 3
}],
"player_MP_updated": [{
"name": "new_mp",
"type": 3
}, {
"name": "previous_mp",
"type": 3
}],
"player_maxHP_updated": [{
"name": "new_hp",
"type": 3
}, {
"name": "previous_hp",
"type": 3
}]
}
